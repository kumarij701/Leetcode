public string LongestPalindrome(string s) {
        int sLength =  s.Length;
        //string returnString; 
        var sArray = s.ToArray();

        //List<char> returns = new List<char>();
        int length =0;
        int maxlength =1;
        int k =0;
        int index = 0; 
        for(int i=0; i< sLength; i++)
        {   
            k=0;
            int l = i;
            bool isPalindrome = false;
            for(int j=i; j< sLength  ; j++)
            {
                length = 0; 
                int left = i;
                int right = j;

                while(left < right)
                {
                    if(s[left] != s[right]) 
                    {
                        isPalindrome = false;
                        break;
                    }
                    left++;
                    right--;

                    isPalindrome = true;
                }

                if(isPalindrome)
                {
                    length = j - i + 1;
                    if (length > maxlength)
                    {
                        index = i;
                        maxlength = length;
                    }
                }
            }
        }
        return s.Substring(index , maxlength);
    }
